{
	"_version": "1.83.0",
	"sap.app": {
		"id": "assetmanagementemployee",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:lrop",
			"version": "1.22.0",
			"toolsId": "5f8fca65-2cfb-4e35-b885-f365eef258ea"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/v4/employee/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.01"
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.146.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.templates": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "assetmanagementemployee.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"pattern": ":?query:",
					"name": "EmployeeList",
					"target": "EmployeeList"
				},
				{
					"pattern": "Employee({key}):?query:",
					"name": "EmployeeObjectPage",
					"target": "EmployeeObjectPage"
				},
				{
					"pattern": "Employee({key})/assets({key2}):?query:",
					"name": "AssetObjectPage",
					"target": "AssetObjectPage"
				}
			],
			"targets": {
				"EmployeeList": {
					"type": "Component",
					"id": "EmployeeList",
					"name": "sap.fe.templates.ListReport",
					"options": {
						"settings": {
							"contextPath": "/Employee",
							"variantManagement": "Page",
							"navigation": {
								"Employee": {
									"detail": {
										"route": "EmployeeObjectPage"
									}
								}
							},
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.LineItem": {
									"tableSettings": {
										"type": "ResponsiveTable"
									}
								}
							}
						}
					}
				},
				"EmployeeObjectPage": {
					"type": "Component",
					"id": "EmployeeObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/Employee",
							"navigation": {
								"assets": {
									"detail": {
										"route": "AssetObjectPage"
									}
								}
							}
						}
					}
				},
				"AssetObjectPage": {
					"type": "Component",
					"id": "AssetObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/Employee/assets"
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fiori": {
		"registrationIds": [],
		"archeType": "transactional"
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": true
		}
	},
	"sap.cloud": {
		"public": true,
		"service": "customui"
	}
}