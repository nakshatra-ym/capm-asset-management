{
  "name": "asset-management",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4.13.0",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-asset-management": "cds watch --open assetmanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-asset-management-employee": "cds watch --open assetmanagementemployee/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked"
      },
      "db": {
        "kind": "hana"
      },
      "html5-repo": true
    }
  },
  "sapux": [
    "app/asset-management",
    "app/asset-management-employee"
  ],
  "workspaces": [
    "app/*"
  ]
}
