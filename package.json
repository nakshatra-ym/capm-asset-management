{
  "name": "asset-management",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-asset-management": "cds watch --open assetmanagement/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
  "requires": {
      "auth": {
        "strategy": "mock",
        "users": {
          "alice": {
            "password": "password123",
            "roles": ["Admin"]
          },
          "bob": {
            "roles": ["User"]
          }
        },
        "[production]": {
          "auth": "xsuaa"
        }
      }
    }
  },
  "sapux": [
    "app/asset-management"
  ],
  "workspaces": [
    "app/*"
  ]
}
